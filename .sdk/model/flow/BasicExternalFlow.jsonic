# BasicExternalFlow

main: kit: flow: BasicExternalFlow:
{
  entity: "external",
  kind: "basic",
  name: "BasicExternalFlow",
  step: [
    {
      match: {
        username: "username01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "external_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicExternalFlow"
}